# This file is installed as /etc/sub2api-autodeploy.env.  Values below are
# examples only; install-autodeploy.sh derives repository URLs and the current
# production branch from the checked-out source by default.

# Source branch that contains the site's customizations.  This is intentionally
# separate from main so a plain main deployment can never discard local work.
SUB2API_AUTODEPLOY_PRODUCTION_REMOTE=fork
SUB2API_AUTODEPLOY_PRODUCTION_REPO_URL=https://github.com/Turtle-Li/sub2api.git
SUB2API_AUTODEPLOY_PRODUCTION_BRANCH=feature/batch-image-foundation

# Merge this fork's main into the disposable production candidate whenever it
# advances.  A normal merge to main is therefore picked up at the next check.
SUB2API_AUTODEPLOY_MERGE_MAIN=true
SUB2API_AUTODEPLOY_MAIN_REMOTE=fork
SUB2API_AUTODEPLOY_MAIN_REPO_URL=https://github.com/Turtle-Li/sub2api.git
SUB2API_AUTODEPLOY_MAIN_BRANCH=main

# Also merge the official upstream main when it advances.  Merge commits exist
# only in the disposable build candidate; the service never pushes to GitHub.
SUB2API_AUTODEPLOY_MERGE_UPSTREAM=true
SUB2API_AUTODEPLOY_UPSTREAM_REMOTE=origin
SUB2API_AUTODEPLOY_UPSTREAM_REPO_URL=https://github.com/Wei-Shaw/sub2api.git
SUB2API_AUTODEPLOY_UPSTREAM_BRANCH=main

SUB2API_PUBLIC_HEALTH_URL=https://www.turtleligpt.com/health
SUB2API_AUTODEPLOY_FAILURE_RETRY_SECONDS=1800
